{
    "name": "cusodede/yii2-s3-module",
    "description": "S3 support module",
    "type": "yii2-module",
    "keywords": [
        "yii2",
        "module",
        "cloud storage",
        "minio",
        "S3"
    ],
    "license": "proprietary",
    "authors": [
        {
            "name": "Pavel Dubrovsky",
            "email": "antikillerxxl@gmail.com"
        },
        {
            "name": "Ivan Suares",
            "email": "pepe_botika69@yahoo.com"
        }
    ],
    "minimum-stability": "dev",
    "require": {
        "php": ">=8.4",
        "yiisoft/yii2": "^2.0.54",
        "aws/aws-sdk-php": "^3.379",
        "pozitronik/yii2-traits": "^1.0.5",
        "pozitronik/yii2-badgewidget": "^2.0.0",
        "kartik-v/yii2-widget-select2": "^2.2.3"
    },
    "require-dev": {
        "yiisoft/yii2-coding-standards": "^3.0",
        "yiisoft/yii2-bootstrap4": "^2.0.10",
        "codeception/codeception": "^5.0.0",
        "codeception/module-asserts" : "^3.0.0",
        "codeception/module-phpbrowser" : "^3.0.0",
        "codeception/module-yii2" : "^2.0.0",
        "codeception/module-db" : "^3.0.0",
        "codeception/module-filesystem" : "^3.0.0",
        "codeception/module-rest": "^3.0.0",
        "codeception/module-cli": "^2.0.0",
        "vlucas/phpdotenv": "^v5.6.0"
    },
    "autoload": {
        "psr-4": {
            "cusodede\\s3\\": "src"
        }
    },
    "config": {
        "process-timeout": 1800,
        "fxp-asset": {
            "enabled": false
        },
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ]
}
