includes:
  - vendor/phpstan/phpstan-phpunit/extension.neon
  - phpstan-baseline.neon
parameters:
  phpVersion:
    min: 80400
    max: 80500
  level: 8
  dynamicConstantNames:
    - YII_ENABLE_ERROR_HANDLER
    - YII_DEBUG
  bootstrapFiles:
    - tests/_bootstrap.php
  scanFiles:
    - support/ide-helper.php
  paths:
    - src
    - tests
  excludePaths:
    analyse:
      - tests/_support/_generated
